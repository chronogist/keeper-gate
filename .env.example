KEEPERHUB_API_KEY=kh_your_key_here
KEEPERHUB_BASE_URL=https://app.keeperhub.com/api
# Optional: pin a specific workflow for smoke test. If omitted, smoke uses the first listed workflow.
KEEPERHUB_WORKFLOW_ID=
# Optional: input passed to the workflow's Manual trigger as JSON (defaults to {})
KEEPERHUB_SMOKE_INPUT={}

# OpenRouter — used by examples/langchain-demo to drive the agent
OPENROUTER_API_KEY=sk-or-v1-your_key_here
# Optional: override the model. Default: openai/gpt-oss-20b:free
LANGCHAIN_DEMO_MODEL=
