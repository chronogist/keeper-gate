{
  "name": "@keepergate/openclaw",
  "version": "0.0.3",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --external:openclaw --outfile=dist/index.js",
    "smoke": "tsx --env-file=../../.env test/smoke.ts",
    "typecheck": "tsc --noEmit"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "hooks": {}
  },
  "dependencies": {},
  "peerDependencies": {
    "openclaw": "^2026.4.29"
  },
  "devDependencies": {
    "@keepergate/core": "workspace:*",
    "@types/node": "^22.9.0",
    "esbuild": "^0.28.0",
    "openclaw": "^2026.4.29",
    "tsx": "^4.19.2",
    "typebox": "^1.1.34",
    "typescript": "^5.6.3"
  }
}
